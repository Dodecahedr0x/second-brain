VAULT_PATH=/path/to/your/obsidian/vault

# Optional: cookie arguments passed to yt-dlp for YouTube metadata, transcripts,
# and discovery search. Lets the agent bypass YouTube bot-gating so it can read
# upload dates (recency filtering) and auto-subtitles. Leave empty to run
# unauthenticated (YouTube discovery falls back to relevance-only, best-effort).
# Set this on a machine that has a logged-in browser profile or an exported
# cookies file. Examples:
#   YT_COOKIES="--cookies-from-browser chrome"
#   YT_COOKIES="--cookies /home/you/yt-cookies.txt"
YT_COOKIES=
